///|
fn keyword_of(text : BytesView) -> Keyword? {
  match text.to_owned() {
    b"abstract" => Some(Abstract)
    b"absurd" => Some(Absurd)
    b"alias" => Some(Alias)
    b"any" => Some(Any)
    b"as" => Some(As)
    b"assert" => Some(Assert)
    b"assume" => Some(Assume)
    b"at" => Some(At)
    b"axiom" => Some(Axiom)
    b"begin" => Some(Begin)
    b"break" => Some(Break)
    b"by" => Some(By)
    b"check" => Some(Check)
    b"clone" => Some(Clone)
    b"coinductive" => Some(Coinductive)
    b"constant" => Some(Constant)
    b"continue" => Some(Continue)
    b"diverges" => Some(Diverges)
    b"do" => Some(Do)
    b"done" => Some(Done)
    b"downto" => Some(Downto)
    b"else" => Some(Else)
    b"end" => Some(End)
    b"ensures" => Some(Ensures)
    b"epsilon" => Some(Epsilon)
    b"exception" => Some(Exception)
    b"exists" => Some(Exists)
    b"export" => Some(Export)
    b"false" => Some(False)
    b"for" => Some(For)
    b"forall" => Some(Forall)
    b"fun" => Some(Fun)
    b"function" => Some(Function)
    b"ghost" => Some(Ghost)
    b"goal" => Some(Goal)
    b"if" => Some(If)
    b"import" => Some(Import)
    b"in" => Some(In)
    b"inductive" => Some(Inductive)
    b"invariant" => Some(Invariant)
    b"label" => Some(Label)
    b"lemma" => Some(Lemma)
    b"let" => Some(Let)
    b"match" => Some(Match)
    b"meta" => Some(Meta)
    b"module" => Some(Module)
    b"mutable" => Some(Mutable)
    b"not" => Some(Not)
    b"old" => Some(Old)
    b"partial" => Some(Partial)
    b"predicate" => Some(Predicate)
    b"private" => Some(Private)
    b"pure" => Some(Pure)
    b"raise" => Some(Raise)
    b"raises" => Some(Raises)
    b"reads" => Some(Reads)
    b"rec" => Some(Rec)
    b"requires" => Some(Requires)
    b"return" => Some(Return)
    b"returns" => Some(Returns)
    b"scope" => Some(Scope)
    b"so" => Some(So)
    b"then" => Some(Then)
    b"theory" => Some(Theory)
    b"to" => Some(To)
    b"true" => Some(True)
    b"try" => Some(Try)
    b"type" => Some(Type)
    b"use" => Some(Use)
    b"val" => Some(Val)
    b"variant" => Some(Variant)
    b"while" => Some(While)
    b"with" => Some(With)
    b"writes" => Some(Writes)
    b"float" => Some(Float)
    b"range" => Some(Range)
    b"ref" => Some(Ref)
    _ => None
  }
}

///|
fn Keyword::spelling(self : Keyword) -> String {
  match self {
    Abstract => "abstract"
    Absurd => "absurd"
    Alias => "alias"
    Any => "any"
    As => "as"
    Assert => "assert"
    Assume => "assume"
    At => "at"
    Axiom => "axiom"
    Begin => "begin"
    Break => "break"
    By => "by"
    Check => "check"
    Clone => "clone"
    Coinductive => "coinductive"
    Constant => "constant"
    Continue => "continue"
    Diverges => "diverges"
    Do => "do"
    Done => "done"
    Downto => "downto"
    Else => "else"
    End => "end"
    Ensures => "ensures"
    Epsilon => "epsilon"
    Exception => "exception"
    Exists => "exists"
    Export => "export"
    False => "false"
    For => "for"
    Forall => "forall"
    Fun => "fun"
    Function => "function"
    Ghost => "ghost"
    Goal => "goal"
    If => "if"
    Import => "import"
    In => "in"
    Inductive => "inductive"
    Invariant => "invariant"
    Label => "label"
    Lemma => "lemma"
    Let => "let"
    Match => "match"
    Meta => "meta"
    Module => "module"
    Mutable => "mutable"
    Not => "not"
    Old => "old"
    Partial => "partial"
    Predicate => "predicate"
    Private => "private"
    Pure => "pure"
    Raise => "raise"
    Raises => "raises"
    Reads => "reads"
    Rec => "rec"
    Requires => "requires"
    Return => "return"
    Returns => "returns"
    Scope => "scope"
    So => "so"
    Then => "then"
    Theory => "theory"
    To => "to"
    True => "true"
    Try => "try"
    Type => "type"
    Use => "use"
    Val => "val"
    Variant => "variant"
    While => "while"
    With => "with"
    Writes => "writes"
    Float => "float"
    Range => "range"
    Ref => "ref"
  }
}

///|
fn Symbol::spelling(self : Symbol) -> String {
  match self {
    And => "/\\"
    Arrow => "->"
    EqualArrow => "=>"
    Amp => "&"
    Bar => "|"
    Colon => ":"
    Comma => ","
    Dot => "."
    DotDot => ".."
    Equal => "="
    Lt => "<"
    Gt => ">"
    LtGt => "<>"
    Minus => "-"
    LeftPar => "("
    LeftSq => "["
    LeftSqBar => "[|"
    LArrow => "<-"
    LRArrow => "<->"
    Or => "\\/"
    RightPar => ")"
    RightSq => "]"
    BarRightSq => "|]"
    Underscore => "_"
    AmpAmp => "&&"
    BarBar => "||"
    LeftBrc => "{"
    RightBrc => "}"
    Semicolon => ";"
  }
}
