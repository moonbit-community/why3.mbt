///|
fn int_theory_key() -> @theory.TheoryKey raise {
  @theory.TheoryKey::new([b"int"], b"Int")
}

///|
test "one static Z3 spec binds independently to two contexts" {
  let left_context = @identity.CompilationContext::new()
  let right_context = @identity.CompilationContext::new()
  let left_environment = @stdlib.minimal_env(left_context)
  let right_environment = @stdlib.minimal_env(right_context)
  let left = bind_z3_profile(left_environment, left_context)
  let right = bind_z3_profile(right_environment, right_context)
  let left_view = left.view()
  let right_view = right.view()
  assert_eq(left_view.driver_meta_group_count, 48)
  assert_eq(left_view.driver_meta_count, 992)
  assert_eq(left_view.validated_snapshot_meta_count, 491)
  assert_eq(left_view.syntax_count, 284)
  assert_eq(left_view.remove_count, 680)
  assert_eq(left_view.theory_prelude_count, 5)
  assert_eq(left_view.result_regexp_count, 11)
  assert_eq(left_view.result_exit_code_count, 0)
  let syntax = left.syntax_entries()
  assert_eq(syntax.length(), 284)
  assert_true(syntax[0].template.length() > 0)
  match syntax[0].symbol {
    @z3.Z3SyntaxType(_) | @z3.Z3SyntaxLogic(_) => ()
  }
  let regexps = left.result_regexp_rules()
  assert_eq(regexps.length(), 11)
  assert_true(regexps[0].pattern.length() > 0)
  assert_eq(left.result_exit_code_rules().length(), 0)
  assert_true(!left_view.context_anchor.same_context(right_view.context_anchor))
  let tasks = @theory.split_theory(
    left_context,
    left_environment.resolve_theory(int_theory_key(), None),
    None,
  )
  assert_true(!tasks.is_empty())
  let updated = left.driver_update(tasks[0])
  assert_true(updated.view().items.length() > tasks[0].view().items.length())
  try right.driver_update(tasks[0]) catch {
    @z3.BindError(diagnostic) => assert_eq(diagnostic.kind, @z3.ContextMismatch)
  } noraise {
    _ => fail("expected cross-context profile use to fail")
  }
}

///|
test "prepared SMT query bytes are target-independent" {
  let context = @identity.CompilationContext::new()
  let environment = @stdlib.minimal_env(context)
  let profile = bind_z3_profile(environment, context)
  let user_type = @logic.TypeSymbol::new_abstract(
    context,
    b"u",
    @identity.Origin::user(b"u", None, []),
    [],
    None,
  )
  let ty = @logic.Ty::app(user_type, [], None)
  let predicate = @logic.LSymbol::new_predicate(
    context,
    b"p",
    @identity.Origin::user(b"p", None, []),
    [ty],
    None,
  )
  let binder = @logic.VSymbol::new(
    context,
    b"x",
    @identity.Origin::user(b"x", None, []),
    ty,
    None,
  )
  let body = @logic.Term::apply_predicate(
    predicate,
    [@logic.Term::variable(binder)],
    None,
  )
  let formula = @logic.Term::quantify(
    ForallQuantifier,
    [binder],
    [],
    body,
    None,
  )
  let proposition = @logic.PrSymbol::new(
    context,
    b"goal",
    @identity.Origin::user(b"goal", None, []),
  )
  let task = @theory.Task::trusted_new(
    context.fresh_id(),
    [
      TheoryDecl(
        @logic.Decl::type_declaration(
          context,
          @identity.Origin::user(b"u", None, []),
          [user_type],
          None,
        ),
      ),
      TheoryDecl(
        @logic.Decl::parameter(
          context,
          @identity.Origin::user(b"p", None, []),
          predicate,
          None,
        ),
      ),
      TheoryDecl(
        @logic.Decl::proposition(
          context,
          @identity.Origin::user(b"goal", None, []),
          Pgoal,
          proposition,
          formula,
          None,
        ),
      ),
    ],
    None,
  )
  let query = prepare_and_print_z3_task(profile, context, task)
  assert_eq(
    query.bytes(),
    b";;; generated by SMT-LIB2 driver\n;;; SMT-LIB2 driver: bit-vectors, common part\n;;; generated by SMT-LIB strings\n(declare-sort u 0)\n(declare-fun p (u) Bool)\n(assert (not (forall ((x u)) (p x))))\n(check-sat)\n",
  )
}
