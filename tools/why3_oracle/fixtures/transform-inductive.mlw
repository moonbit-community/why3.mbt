theory InductiveSnapshot
  use why3.WellFounded.WellFounded
  use int.Int
  use map.Map
  use map.Const

  goal well_founded_smoke :
    let relation = const (const True) in
    well_founded relation /\ get (get relation 0) 0 = True
end
