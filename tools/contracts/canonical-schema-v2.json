{
  "schemaVersion": 2,
  "recordVersion": 2,
  "encoding": {
    "json": "UTF-8, no insignificant whitespace, object fields in schema order, one LF terminator",
    "bytes": "lowercase hexadecimal without prefix",
    "integers": "base-10 string with optional leading minus and no redundant leading zeroes",
    "real": [
      "significand-decimal",
      "pow2-decimal",
      "pow5-decimal"
    ],
    "option": {
      "none": [
        "none"
      ],
      "some": [
        "some",
        "<value>"
      ]
    },
    "orderedSequence": "JSON array in semantic source/history order",
    "semanticMap": "JSON array of [key,value] entries sorted by canonical byte key, then recursively by encoded value",
    "attributes": "JSON array of lowercase-hex Bytes values sorted lexicographically",
    "path": "fixture-root-relative POSIX path encoded as lowercase-hex bytes"
  },
  "identity": {
    "globalSymbols": "assign [symbol-kind, zero-based-index] at first preorder encounter across declarations, references, metas, and clone witnesses",
    "boundVariables": "de Bruijn index",
    "contextTokenSerialized": false,
    "runtimeTagsSerialized": false,
    "physicalAddressesSerialized": false,
    "sourceNamesPreserved": true,
    "originKindSerialized": true,
    "generatedStageSerialized": true
