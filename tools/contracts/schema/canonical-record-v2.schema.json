{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/moonbit-community/why3.mbt/tools/contracts/schema/canonical-record-v2.schema.json",
  "title": "why3.mbt portable canonical record v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "semantic_profile_sha256",
    "fixture",
    "source_sha256",
    "scope",
    "unit_kind",
    "unit_name_hex",
    "stage",
    "canonical_sha256",
    "canonical"
  ],
  "properties": {
    "schema": {
      "const": 2
    },
    "semantic_profile_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "fixture": {
      "$ref": "#/$defs/relativePosixPath"
    },
    "source_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "scope": {
      "enum": [
        "unit",
        "goal"
      ]
    },
    "unit_kind": {
      "enum": [
        "theory",
        "module"
      ]
    },
    "unit_name_hex": {
      "$ref": "#/$defs/bytesHex"
    },
    "goal_name_hex": {
      "$ref": "#/$defs/bytesHex"
    },
    "goal_ordinal": {
      "type": "integer",
      "minimum": 0
    },
    "stage": {
      "type": "string",
      "pattern": "^(typed-semantic|raw-task|driver-update|transform:[a-z][a-z0-9_]*|prepared-task|smt-tokens|prover-result)$"
    },
    "canonical_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "canonical": true
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "scope": {
            "const": "goal"
          }
        },
        "required": [
          "scope"
        ]
      },
      "then": {
        "required": [
          "goal_name_hex",
          "goal_ordinal"
        ]
      },
      "else": {
        "not": {
          "anyOf": [
            {
              "required": [
                "goal_name_hex"
              ]
            },
            {
              "required": [
                "goal_ordinal"
              ]
            }
          ]
        }
      }
    }
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "bytesHex": {
      "type": "string",
      "pattern": "^(?:[0-9a-f]{2})*$"
    },
    "relativePosixPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\\\\\).+$"
    }
  }
}
