{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/moonbit-community/why3.mbt/tools/contracts/schema/reference-goal-envelope-v1.schema.json",
  "title": "Why3 reference goal envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "reference_context_sha256",
    "record",
    "reference_diagnostics"
  ],
  "properties": {
    "reference_context_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "record": {
      "$ref": "canonical-record-v2.schema.json"
    },
    "reference_diagnostics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "why3_task_checksum_v6": {
          "type": "string",
          "minLength": 1
        },
        "why3_shape_version": {
          "const": 6
        }
      }
    }
  }
}
