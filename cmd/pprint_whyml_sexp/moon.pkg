// Native command that prints WhyML parser output as Why3-compatible S-expressions.
import {
  "moonbit-community/prettyprinter",
  "moonbit-community/why3/parser",
  "moonbitlang/core/encoding/utf8",
  "moonbitlang/core/env",
  "moonbitlang/async",
  "moonbitlang/async/fs",
  "moonbitlang/async/stdio",
}

supported_targets = "+native"

pkgtype(kind: "executable")
