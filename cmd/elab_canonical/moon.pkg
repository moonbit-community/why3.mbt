// Native Stage-06 differential helper. Canonicalization stays in the
// all-target oracle/canonical package; this executable only performs I/O.
import {
  "moonbit-community/why3/core/identity",
  "moonbit-community/why3/core/logic",
  "moonbit-community/why3/core/theory",
  "moonbit-community/why3/elab",
  "moonbit-community/why3/environment",
  "moonbit-community/why3/oracle/canonical",
  "moonbit-community/why3/parser",
  "moonbit-community/why3/pipeline",
  "moonbit-community/why3/printer/smtv2",
  "moonbit-community/why3/stdlib",
  "moonbit-community/why3/transform",
  "moonbit-community/why3/vc",
  "moonbitlang/core/encoding/utf8",
  "moonbitlang/core/env",
  "moonbitlang/async",
  "moonbitlang/async/fs",
  "moonbitlang/async/stdio",
}

supported_targets = "+native"

pkgtype(kind: "executable")
